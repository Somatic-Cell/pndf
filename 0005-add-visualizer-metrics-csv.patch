+def normal_error_metrics(gt: np.ndarray, rec: np.ndarray, coverage: Optional[np.ndarray] = None) -> dict[str, float | int]:
+    """Dense texel-level normal error statistics for a reconstructed PL normal map."""
+    err = angular_error_deg(gt, rec)
+    unit_gt = nxy_to_unit(gt)
+    unit_rec = nxy_to_unit(rec)
+    mse = float(np.mean(np.sum((unit_gt - unit_rec) ** 2, axis=-1)))
+    out: dict[str, float | int] = {
+        "mean_ang_deg": float(np.mean(err)),
+        "p50_ang_deg": float(np.percentile(err, 50)),
+        "p95_ang_deg": float(np.percentile(err, 95)),
+        "p99_ang_deg": float(np.percentile(err, 99)),
+        "max_ang_deg": float(np.max(err)),
+        "normal_mse": mse,
+        "normal_psnr_db": float(10.0 * np.log10(4.0 / (mse + EPS))),
+    }
+    if coverage is not None:
+        covered = int(np.count_nonzero(coverage))
+        total = int(coverage.size)
+        out["covered_pixels"] = covered
+        out["total_pixels"] = total
+        out["uncovered_pixels"] = total - covered
+        out["coverage_ratio"] = float(covered / max(total, 1))
+    return out
+
+
+def write_metrics_csv(path: Path, row: dict[str, object]) -> None:
+    path.parent.mkdir(parents=True, exist_ok=True)
+    with path.open("w", newline="", encoding="utf-8") as f:
+        writer = csv.DictWriter(f, fieldnames=list(row.keys()))
+        writer.writeheader()
+        writer.writerow(row)
+
+
