+#include "pndf/edge_collapse.hpp"
+#include "pndf/mesh_io.hpp"
+#include "pndf/normal_map.hpp"
+#include "pndf/torus_mesh.hpp"
+
+#include <algorithm>
+#include <array>
+#include <cmath>
+#include <cstdint>
+#include <filesystem>
+#include <iostream>
+#include <limits>
+#include <queue>
+#include <sstream>
+#include <stdexcept>
+#include <string>
+#include <unordered_map>
+#include <unordered_set>
+#include <vector>
+
+using namespace pndf;
+
+namespace {
+
+struct Options {
+    std::string input;
+    std::string output;
+    int target = 0;
+    QemMode mode = QemMode::NormalOnly;
+    int iterations = 5;
+    int flip_passes = 1;
+    int relocate_passes = 1;
+    double relocate_step_pixels = 1.0;
+    int rebuild_interval = 50000;
+    int progress_interval = 50000;
+    bool quiet = false;
+};
+
+static void usage() {
+    std::cerr
+        << "Usage:\n"
+        << "  pndf_run_pnm_aniso --input nxy.bin --output meshbin --target N [options]\n\n"
+        << "Options:\n"
+        << "  --mode normal|4d              Collapse QEM used inside each stage. Default: normal.\n"
+        << "  --iterations N                Number of staged collapse/align iterations. Default: 5.\n"
+        << "  --flip-passes N               Edge flip passes after each stage. Default: 1.\n"
+        << "  --relocate-passes N           Vertex relocation passes after each stage. Default: 1.\n"
+        << "  --relocate-step-pixels X      Candidate relocation step in texels. Default: 1.0.\n"
+        << "  --rebuild-interval N          QEM heap rebuild interval. Default: 50000.\n"
+        << "  --progress-interval N         QEM progress interval. Default: 50000.\n"
+        << "  --quiet                       Reduce progress output.\n\n"
+        << "This is a PNM-aware anisotropic optimizer. It does not use the CVPR 2025\n"
+        << "normal-integration surface metric and does not use a p-NDF proxy term.\n"
+        << "It borrows the operation pattern: staged collapse interleaved with edge\n"
+        << "flip and vertex relocation. Flip/relocation minimize local normal-field\n"
+        << "reconstruction energy on the position-normal graph.\n";
+}
+
+static std::uint64_t edge_key(int a, int b) {
+    if (a > b) std::swap(a, b);
+    return (std::uint64_t(std::uint32_t(a)) << 32) | std::uint32_t(b);
+}
+
+static bool face_has(const Face& f, int v) {
+    return f.v[0] == v || f.v[1] == v || f.v[2] == v;
+}
+
+static std::array<Vec2, 3> unwrapped_uv_for_indices(const TorusMesh& mesh, int a, int b, int c) {
+    std::array<Vec2, 3> uv{};
+    uv[0] = mesh.vertices[a].uv;
+    uv[1] = unwrap_near(mesh.vertices[b].uv, uv[0]);
+    uv[2] = unwrap_near(mesh.vertices[c].uv, uv[0]);
+    return uv;
+}
+
+static double signed_area(const std::array<Vec2, 3>& uv) {
+    const Vec2 e0 = uv[1] - uv[0];
+    const Vec2 e1 = uv[2] - uv[0];
+    return e0.x * e1.y - e0.y * e1.x;
+}
+
+static Vec2 lerp_nxy(const TorusMesh& mesh, int a, int b, int c, double l0, double l1, double l2) {
+    return clamp_projected_normal(mesh.vertices[a].nxy * l0 + mesh.vertices[b].nxy * l1 + mesh.vertices[c].nxy * l2);
+}
+
+static double projected_error2(Vec2 a, Vec2 b) {
+    a = clamp_projected_normal(a);
+    b = clamp_projected_normal(b);
+    const double dx = a.x - b.x;
+    const double dy = a.y - b.y;
+    return dx * dx + dy * dy;
+}
+
+static double triangle_energy_indices(const TorusMesh& mesh, const NormalMap& normal_map, int a, int b, int c) {
+    if (a == b || b == c || c == a) return std::numeric_limits<double>::infinity();
+    if (!mesh.vertices[a].alive || !mesh.vertices[b].alive || !mesh.vertices[c].alive) return std::numeric_limits<double>::infinity();
+    const auto uv = unwrapped_uv_for_indices(mesh, a, b, c);
+    const double area2 = std::abs(signed_area(uv));
+    if (area2 < 1e-18) return std::numeric_limits<double>::infinity();
+
+    // Small deterministic quadrature over the triangle. This is deliberately a
+    // PNM normal-field energy, not a normal-integration surface energy.
+    static constexpr std::array<std::array<double, 3>, 7> samples{{
+        {{1.0/3.0, 1.0/3.0, 1.0/3.0}},
+        {{0.60, 0.20, 0.20}}, {{0.20, 0.60, 0.20}}, {{0.20, 0.20, 0.60}},
+        {{0.80, 0.10, 0.10}}, {{0.10, 0.80, 0.10}}, {{0.10, 0.10, 0.80}},
+    }};
+
+    double e = 0.0;
+    for (const auto& s : samples) {
+        const Vec2 u = uv[0] * s[0] + uv[1] * s[1] + uv[2] * s[2];
+        const Vec2 nhat = lerp_nxy(mesh, a, b, c, s[0], s[1], s[2]);
+        const Vec2 gt = normal_map.sample_periodic(u);
+        e += projected_error2(nhat, gt);
+    }
+    return area2 * e / static_cast<double>(samples.size());
+}
+
+static double face_energy(const TorusMesh& mesh, const NormalMap& normal_map, int fi) {
+    const Face& f = mesh.faces[fi];
+    if (!f.alive) return 0.0;
+    return triangle_energy_indices(mesh, normal_map, f.v[0], f.v[1], f.v[2]);
+}
+
+static std::vector<int> incident_live_faces(const TorusMesh& mesh, int v) {
+    std::vector<int> out;
+    if (v < 0 || v >= static_cast<int>(mesh.vertices.size())) return out;
+    for (int fi : mesh.vertices[v].faces) {
+        if (fi >= 0 && fi < static_cast<int>(mesh.faces.size()) && mesh.faces[fi].alive && face_has(mesh.faces[fi], v)) out.push_back(fi);
+    }
+    std::sort(out.begin(), out.end());
+    out.erase(std::unique(out.begin(), out.end()), out.end());
+    return out;
+}
+
+static std::vector<int> live_neighbors(const TorusMesh& mesh, int v) {
+    std::vector<int> out;
+    for (int fi : incident_live_faces(mesh, v)) {
+        const Face& f = mesh.faces[fi];
+        for (int k = 0; k < 3; ++k) {
+            int w = f.v[k];
+            if (w != v && mesh.vertices[w].alive) out.push_back(w);
+        }
+    }
+    std::sort(out.begin(), out.end());
+    out.erase(std::unique(out.begin(), out.end()), out.end());
+    return out;
+}
+
+static bool relocation_nonflipping(TorusMesh& mesh, int v, Vec2 new_uv) {
+    const Vec2 old_uv = mesh.vertices[v].uv;
+    mesh.vertices[v].uv = fract(new_uv);
+    bool ok = true;
+    for (int fi : incident_live_faces(mesh, v)) {
+        const Face& f = mesh.faces[fi];
+        const auto uv = unwrapped_face_uvs(mesh, f);
+        const double area = signed_area(uv);
+        if (std::abs(area) < 1e-18) { ok = false; break; }
+    }
+    mesh.vertices[v].uv = old_uv;
+    return ok;
+}
+
+static double vertex_local_energy(TorusMesh& mesh, const NormalMap& normal_map, int v, Vec2 uv, Vec2 nxy) {
+    const Vec2 old_uv = mesh.vertices[v].uv;
+    const Vec2 old_n = mesh.vertices[v].nxy;
+    mesh.vertices[v].uv = fract(uv);
+    mesh.vertices[v].nxy = clamp_projected_normal(nxy);
+    double e = 0.0;
+    for (int fi : incident_live_faces(mesh, v)) e += face_energy(mesh, normal_map, fi);
+    mesh.vertices[v].uv = old_uv;
+    mesh.vertices[v].nxy = old_n;
+    return e;
+}
+
+static int relocate_pass(TorusMesh& mesh, const NormalMap& normal_map, double step_pixels) {
+    const double sx = step_pixels / std::max(1, mesh.width);
+    const double sy = step_pixels / std::max(1, mesh.height);
+    int moved = 0;
+    std::vector<int> verts;
+    verts.reserve(mesh.vertices.size());
+    for (int i = 0; i < static_cast<int>(mesh.vertices.size()); ++i) if (mesh.vertices[i].alive) verts.push_back(i);
+
+    for (int v : verts) {
+        if (!mesh.vertices[v].alive) continue;
+        const Vec2 base = mesh.vertices[v].uv;
+        const Vec2 base_n = mesh.vertices[v].nxy;
+        double best_e = vertex_local_energy(mesh, normal_map, v, base, base_n);
+        Vec2 best_uv = base;
+
+        std::vector<Vec2> candidates;
+        candidates.push_back({base.x + sx, base.y});
+        candidates.push_back({base.x - sx, base.y});
+        candidates.push_back({base.x, base.y + sy});
+        candidates.push_back({base.x, base.y - sy});
+        candidates.push_back({base.x + sx, base.y + sy});
+        candidates.push_back({base.x + sx, base.y - sy});
+        candidates.push_back({base.x - sx, base.y + sy});
+        candidates.push_back({base.x - sx, base.y - sy});
+
+        const auto nbrs = live_neighbors(mesh, v);
+        if (!nbrs.empty()) {
+            Vec2 centroid{0.0, 0.0};
+            for (int w : nbrs) centroid += unwrap_near(mesh.vertices[w].uv, base);
+            centroid = centroid / static_cast<double>(nbrs.size());
+            candidates.push_back(base + (centroid - base) * 0.5);
+        }
+
+        for (Vec2 cand : candidates) {
+            Vec2 delta = cand - base;
+            double alpha = 1.0;
+            for (int ls = 0; ls < 8; ++ls) {
+                const Vec2 trial = base + delta * alpha;
+                if (relocation_nonflipping(mesh, v, trial)) {
+                    const Vec2 trial_n = normal_map.sample_periodic(trial);
+                    const double e = vertex_local_energy(mesh, normal_map, v, trial, trial_n);
+                    if (std::isfinite(e) && e + 1e-15 < best_e) {
+                        best_e = e;
+                        best_uv = trial;
+                    }
+                    break;
+                }
+                alpha *= 0.5;
+            }
+        }
+
+        if (norm2(wrap_delta(best_uv - base)) > 1e-20) {
+            mesh.vertices[v].uv = fract(best_uv);
+            mesh.vertices[v].q_origin = mesh.vertices[v].uv;
+            mesh.vertices[v].nxy = normal_map.sample_periodic(best_uv);
+            mesh.vertices[v].version++;
+            moved++;
+        }
+    }
+    return moved;
+}
+
+struct EdgeAdj { int a = -1, b = -1; std::vector<int> faces; };
+
+static std::unordered_map<std::uint64_t, EdgeAdj> build_edge_adjacency(const TorusMesh& mesh) {
+    std::unordered_map<std::uint64_t, EdgeAdj> edges;
+    for (int fi = 0; fi < static_cast<int>(mesh.faces.size()); ++fi) {
+        const Face& f = mesh.faces[fi];
+        if (!f.alive) continue;
+        for (int k = 0; k < 3; ++k) {
+            int a = f.v[k];
+            int b = f.v[(k + 1) % 3];
+            const std::uint64_t key = edge_key(a, b);
+            auto& e = edges[key];
+            e.a = std::min(a, b);
+            e.b = std::max(a, b);
+            e.faces.push_back(fi);
+        }
+    }
+    return edges;
+}
+
+static int opposite_vertex(const Face& f, int a, int b) {
+    for (int k = 0; k < 3; ++k) {
+        int v = f.v[k];
+        if (v != a && v != b) return v;
+    }
+    return -1;
+}
+
+static bool valid_flip_candidate(const TorusMesh& mesh, int a, int b, int c, int d, const std::unordered_map<std::uint64_t, EdgeAdj>& edges) {
+    if (a < 0 || b < 0 || c < 0 || d < 0) return false;
+    if (a == b || a == c || a == d || b == c || b == d || c == d) return false;
+    if (!mesh.vertices[a].alive || !mesh.vertices[b].alive || !mesh.vertices[c].alive || !mesh.vertices[d].alive) return false;
+    const auto it = edges.find(edge_key(c, d));
+    if (it != edges.end()) return false; // would create duplicate edge
+    return true;
+}
+
+static double pair_energy(const TorusMesh& mesh, const NormalMap& normal_map, const std::array<int,3>& t0, const std::array<int,3>& t1) {
+    const double e0 = triangle_energy_indices(mesh, normal_map, t0[0], t0[1], t0[2]);
+    const double e1 = triangle_energy_indices(mesh, normal_map, t1[0], t1[1], t1[2]);
+    if (!std::isfinite(e0) || !std::isfinite(e1)) return std::numeric_limits<double>::infinity();
+    return e0 + e1;
+}
+
+static int flip_pass(TorusMesh& mesh, const NormalMap& normal_map) {
+    auto edges = build_edge_adjacency(mesh);
+    int flipped = 0;
+    std::vector<std::uint64_t> keys;
+    keys.reserve(edges.size());
+    for (const auto& kv : edges) keys.push_back(kv.first);
+
+    for (std::uint64_t key : keys) {
+        auto it = edges.find(key);
+        if (it == edges.end()) continue;
+        const EdgeAdj& ea = it->second;
+        if (ea.faces.size() != 2) continue;
+        const int f0i = ea.faces[0];
+        const int f1i = ea.faces[1];
+        if (f0i < 0 || f1i < 0 || f0i >= static_cast<int>(mesh.faces.size()) || f1i >= static_cast<int>(mesh.faces.size())) continue;
+        if (!mesh.faces[f0i].alive || !mesh.faces[f1i].alive) continue;
+        const int a = ea.a;
+        const int b = ea.b;
+        const int c = opposite_vertex(mesh.faces[f0i], a, b);
+        const int d = opposite_vertex(mesh.faces[f1i], a, b);
+        if (!valid_flip_candidate(mesh, a, b, c, d, edges)) continue;
+
+        const double before = face_energy(mesh, normal_map, f0i) + face_energy(mesh, normal_map, f1i);
+        std::array<int,3> cand0a{c, d, a};
+        std::array<int,3> cand0b{d, c, b};
+        std::array<int,3> cand1a{d, c, a};
+        std::array<int,3> cand1b{c, d, b};
+        const double e0 = pair_energy(mesh, normal_map, cand0a, cand0b);
+        const double e1 = pair_energy(mesh, normal_map, cand1a, cand1b);
+
+        if (e0 + 1e-15 < before && e0 <= e1) {
+            mesh.faces[f0i].v = cand0a;
+            mesh.faces[f1i].v = cand0b;
+            flipped++;
+        } else if (e1 + 1e-15 < before) {
+            mesh.faces[f0i].v = cand1a;
+            mesh.faces[f1i].v = cand1b;
+            flipped++;
+        }
+    }
+    if (flipped > 0) mesh.rebuild_vertex_face_adjacency();
+    return flipped;
+}
+
+static std::vector<int> make_stage_targets(int initial_vertices, int final_target, int iterations) {
+    std::vector<int> stages;
+    if (final_target <= 0 || final_target >= initial_vertices) return stages;
+    iterations = std::max(1, iterations);
+    const int start = std::min(initial_vertices, std::max(final_target, final_target * 10));
+    if (start < initial_vertices) stages.push_back(start);
+    for (int i = 1; i <= iterations; ++i) {
+        const double t = static_cast<double>(i) / static_cast<double>(iterations);
+        const double v = std::exp((1.0 - t) * std::log(static_cast<double>(start)) + t * std::log(static_cast<double>(final_target)));
+        const int stage = std::max(final_target, static_cast<int>(std::llround(v)));
+        if (stages.empty() || stage < stages.back()) stages.push_back(stage);
+    }
+    if (stages.empty() || stages.back() != final_target) stages.push_back(final_target);
+    return stages;
+}
+
+static Options parse(int argc, char** argv) {
+    Options opt;
+    for (int i = 1; i < argc; ++i) {
+        std::string a = argv[i];
+        auto next = [&]() -> std::string {
+            if (i + 1 >= argc) { usage(); std::exit(2); }
+            return argv[++i];
+        };
+        if (a == "--input") opt.input = next();
+        else if (a == "--output") opt.output = next();
+        else if (a == "--target") opt.target = std::stoi(next());
+        else if (a == "--mode") {
+            const std::string m = next();
+            if (m == "normal") opt.mode = QemMode::NormalOnly;
+            else if (m == "4d") opt.mode = QemMode::Qem4D;
+            else { usage(); std::exit(2); }
+        }
+        else if (a == "--iterations") opt.iterations = std::stoi(next());
+        else if (a == "--flip-passes") opt.flip_passes = std::stoi(next());
+        else if (a == "--relocate-passes") opt.relocate_passes = std::stoi(next());
+        else if (a == "--relocate-step-pixels") opt.relocate_step_pixels = std::stod(next());
+        else if (a == "--rebuild-interval") opt.rebuild_interval = std::stoi(next());
+        else if (a == "--progress-interval") opt.progress_interval = std::stoi(next());
+        else if (a == "--quiet") opt.quiet = true;
+        else { usage(); std::exit(2); }
+    }
+    if (opt.input.empty() || opt.output.empty() || opt.target <= 0) { usage(); std::exit(2); }
+    return opt;
+}
+
+} // namespace
+
+int main(int argc, char** argv) {
+    try {
+        Options opt = parse(argc, argv);
+        NormalMap map = read_nxy_binary(opt.input);
+        TorusMesh mesh;
+        mesh.build_full_torus(map);
+
+        const int initial_vertices = mesh.alive_vertex_count();
+        const std::vector<int> stages = make_stage_targets(initial_vertices, opt.target, opt.iterations);
+        if (!opt.quiet) {
+            std::cerr << "pnm_aniso stages:";
+            for (int s : stages) std::cerr << ' ' << s;
+            std::cerr << "\n";
+        }
+
+        for (int stage : stages) {
+            if (mesh.alive_vertex_count() > stage) {
+                CollapseOptions copt;
+                copt.target_vertices = stage;
+                copt.mode = opt.mode;
+                copt.verbose = !opt.quiet;
+                copt.rebuild_interval = opt.rebuild_interval;
+                copt.progress_interval = opt.progress_interval;
+                auto stats = simplify_qem(mesh, copt);
+                if (!opt.quiet) std::cerr << "stage collapse target=" << stage << " finalV=" << stats.final_vertices << " sec=" << stats.total_seconds << "\n";
+            }
+
+            for (int p = 0; p < opt.flip_passes; ++p) {
+                const int n = flip_pass(mesh, map);
+                if (!opt.quiet) std::cerr << "stage=" << stage << " flipPass=" << p << " flipped=" << n << "\n";
+            }
+            for (int p = 0; p < opt.relocate_passes; ++p) {
+                const int n = relocate_pass(mesh, map, opt.relocate_step_pixels);
+                mesh.rebuild_vertex_face_adjacency();
+                if (!opt.quiet) std::cerr << "stage=" << stage << " relocatePass=" << p << " moved=" << n << "\n";
+            }
+        }
+
+        if (std::filesystem::path(opt.output).parent_path() != std::filesystem::path{}) {
+            std::filesystem::create_directories(std::filesystem::path(opt.output).parent_path());
+        }
+        write_mesh_binary(mesh, opt.output);
+        std::cout << "final_vertices," << mesh.alive_vertex_count() << "\n";
+        std::cout << "final_faces," << mesh.alive_face_count() << "\n";
+        std::cout << "output," << opt.output << "\n";
+        return 0;
+    } catch (const std::exception& e) {
+        std::cerr << "error: " << e.what() << "\n";
+        return 1;
+    }
+}
