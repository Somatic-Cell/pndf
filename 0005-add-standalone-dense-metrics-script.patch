+#!/usr/bin/env python3
+"""
+Dense normal-map metrics for PNDF/QEM meshbin outputs.
+
+This is intentionally standalone and does not import visualize_pndf_mesh.py, so it
+can be added even if the visualizer has local edits. It reads:
+
+  nxy.bin:
+    int32 N, float nx[N*N], float ny[N*N]
+    or int32 W, int32 H, float nx[W*H], float ny[W*H]
+
+  meshbin:
+    int32 width, int32 height, int32 V, int32 F,
+    V * (float u, v, nx, ny), F * (int32 i0, i1, i2)
+    or legacy int32 N, int32 V, int32 F, ...
+
+It reconstructs the simplified mesh as a periodic piecewise-linear normal field
+on all texel centers and writes a one-line CSV with angular error metrics and
+coverage statistics.
+"""
+from __future__ import annotations
+
+import argparse
+import csv
+import math
+from pathlib import Path
+
+import numpy as np
+
+EPS = 1e-12
+
+
+def clamp_nxy(nxy: np.ndarray) -> np.ndarray:
+    n = np.linalg.norm(nxy, axis=-1, keepdims=True)
+    return (nxy * np.minimum(1.0, 0.999 / np.maximum(n, EPS))).astype(np.float32)
+
+
+def nxy_to_unit(nxy: np.ndarray) -> np.ndarray:
+    z = np.sqrt(np.maximum(0.0, 1.0 - np.sum(nxy * nxy, axis=-1, keepdims=True)))
+    n = np.concatenate([nxy, z], axis=-1)
+    n /= np.maximum(np.linalg.norm(n, axis=-1, keepdims=True), EPS)
+    return n.astype(np.float32)
+
+
+def angular_error_deg(gt: np.ndarray, rec: np.ndarray) -> np.ndarray:
+    d = np.sum(nxy_to_unit(gt) * nxy_to_unit(rec), axis=-1).clip(-1.0, 1.0)
+    return np.degrees(np.arccos(d)).astype(np.float32)
+
+
+def wrap_delta(d: np.ndarray) -> np.ndarray:
+    return (d + 0.5) % 1.0 - 0.5
+
+
+def load_nxy_bin(path: Path) -> np.ndarray:
+    data = path.read_bytes()
+    if len(data) < 4:
+        raise ValueError(f"nxy file too small: {path}")
+    ints = np.frombuffer(data[:8], dtype=np.int32, count=min(2, len(data) // 4))
+    N = int(ints[0])
+    size_single_header = 4 + 2 * N * N * 4
+    if N > 0 and len(data) == size_single_header:
+        arr = np.frombuffer(data[4:], dtype=np.float32)
+        nx = arr[: N * N].reshape(N, N)
+        ny = arr[N * N :].reshape(N, N)
+        return clamp_nxy(np.stack([nx, ny], axis=-1).copy())
+
+    if len(ints) >= 2:
+        W, H = int(ints[0]), int(ints[1])
+        size_two_header = 8 + 2 * W * H * 4
+        if W > 0 and H > 0 and len(data) == size_two_header:
+            arr = np.frombuffer(data[8:], dtype=np.float32)
+            nx = arr[: W * H].reshape(H, W)
+            ny = arr[W * H :].reshape(H, W)
+            return clamp_nxy(np.stack([nx, ny], axis=-1).copy())
+
+    raise ValueError(f"Could not parse nxy binary {path}; bytes={len(data)}, first int={N}")
+
+
+def normalize_mesh_uv(vertices: np.ndarray, width: int, height: int) -> np.ndarray:
+    uv = vertices[:, :2]
+    if len(uv) > 0 and np.nanmax(np.abs(uv)) > 2.0:
+        vertices[:, 0] = vertices[:, 0] / float(width)
+        vertices[:, 1] = vertices[:, 1] / float(height)
+    vertices[:, :2] = vertices[:, :2] % 1.0
+    vertices[:, 2:4] = clamp_nxy(vertices[:, 2:4])
+    return vertices
+
+
+def load_meshbin(path: Path) -> tuple[int, int, np.ndarray, np.ndarray, str]:
+    data = path.read_bytes()
+    if len(data) < 12:
+        raise ValueError(f"mesh file too small: {path}")
+
+    # Current format: width, height, V, F
+    if len(data) >= 16:
+        width, height, V, F = np.frombuffer(data[:16], dtype=np.int32, count=4)
+        width, height, V, F = int(width), int(height), int(V), int(F)
+        expected = 16 + 16 * V + 12 * F
+        if width > 0 and height > 0 and V >= 0 and F >= 0 and expected == len(data):
+            off = 16
+            vertices = np.frombuffer(data[off : off + 16 * V], dtype=np.float32).reshape(V, 4).copy()
+            off += 16 * V
+            faces = np.frombuffer(data[off : off + 12 * F], dtype=np.int32).reshape(F, 3).copy()
+            return width, height, normalize_mesh_uv(vertices, width, height), faces, "width,height,V,F"
+
+    # Legacy format: N, V, F
+    N, V, F = np.frombuffer(data[:12], dtype=np.int32, count=3)
+    N, V, F = int(N), int(V), int(F)
+    expected = 12 + 16 * V + 12 * F
+    if N > 0 and V >= 0 and F >= 0 and expected == len(data):
+        off = 12
+        vertices = np.frombuffer(data[off : off + 16 * V], dtype=np.float32).reshape(V, 4).copy()
+        off += 16 * V
+        faces = np.frombuffer(data[off : off + 12 * F], dtype=np.int32).reshape(F, 3).copy()
+        return N, N, normalize_mesh_uv(vertices, N, N), faces, "N,V,F"
+
+    raise ValueError(f"Could not parse mesh binary {path}; bytes={len(data)}")
+
+
+def rasterize_mesh_to_grid(vertices: np.ndarray, faces: np.ndarray, H: int, W: int) -> tuple[np.ndarray, np.ndarray]:
+    """Triangle-driven periodic rasterization to texel centers.
+
+    Returns:
+        rec:      H x W x 2 projected normals. Missing pixels are zero-filled.
+        coverage: H x W bool mask. Missing pixels indicate a rasterization/mesh issue.
+    """
+    uv = vertices[:, :2].astype(np.float64) % 1.0
+    vals = vertices[:, 2:4].astype(np.float64)
+    rec = np.zeros((H, W, 2), dtype=np.float32)
+    coverage = np.zeros((H, W), dtype=bool)
+
+    for tri in faces:
+        ids = tri.astype(np.int64)
+        if np.any(ids < 0) or np.any(ids >= len(vertices)):
+            continue
+
+        p0 = uv[ids[0]]
+        p1 = p0 + wrap_delta(uv[ids[1]] - p0)
+        p2 = p0 + wrap_delta(uv[ids[2]] - p0)
+        vv = vals[ids]
+        base_tri = np.stack([p0, p1, p2], axis=0)
+
+        # Draw periodic copies touching the displayed tile.
+        for sy in (-1, 0, 1):
+            for sx in (-1, 0, 1):
+                p = base_tri + np.array([sx, sy], dtype=np.float64)
+                xmin, xmax = p[:, 0].min(), p[:, 0].max()
+                ymin, ymax = p[:, 1].min(), p[:, 1].max()
+                if xmax < 0.0 or xmin > 1.0 or ymax < 0.0 or ymin > 1.0:
+                    continue
+
+                ix0 = max(0, int(math.floor(xmin * W - 1)))
+                ix1 = min(W - 1, int(math.ceil(xmax * W + 1)))
+                iy0 = max(0, int(math.floor(ymin * H - 1)))
+                iy1 = min(H - 1, int(math.ceil(ymax * H + 1)))
+                if ix1 < ix0 or iy1 < iy0:
+                    continue
+
+                xs = (np.arange(ix0, ix1 + 1, dtype=np.float64) + 0.5) / W
+                ys = (np.arange(iy0, iy1 + 1, dtype=np.float64) + 0.5) / H
+                xx, yy = np.meshgrid(xs, ys, indexing="xy")
+                q = np.stack([xx.ravel(), yy.ravel()], axis=-1)
+
+                e0 = p[1] - p[0]
+                e1 = p[2] - p[0]
+                den = e0[0] * e1[1] - e0[1] * e1[0]
+                if abs(den) < 1e-14:
+                    continue
+
+                e2 = q - p[0]
+                a = (e2[:, 0] * e1[1] - e2[:, 1] * e1[0]) / den
+                b = (e0[0] * e2[:, 1] - e0[1] * e2[:, 0]) / den
+                c = 1.0 - a - b
+                inside = (a >= -1e-7) & (b >= -1e-7) & (c >= -1e-7)
+                if not np.any(inside):
+                    continue
+
+                interp = c[:, None] * vv[0] + a[:, None] * vv[1] + b[:, None] * vv[2]
+                coords = q[inside]
+                px = np.clip(np.floor(coords[:, 0] * W).astype(np.int64), 0, W - 1)
+                py = np.clip(np.floor(coords[:, 1] * H).astype(np.int64), 0, H - 1)
+                rec[py, px] = interp[inside].astype(np.float32)
+                coverage[py, px] = True
+
+    rec = clamp_nxy(rec)
+    return rec, coverage
+
+
+def compute_metrics(gt: np.ndarray, rec: np.ndarray, coverage: np.ndarray) -> dict[str, float | int]:
+    total = int(coverage.size)
+    covered = int(np.count_nonzero(coverage))
+    uncovered = total - covered
+
+    if covered == 0:
+        raise ValueError("No covered texels; cannot compute metrics")
+
+    gt_c = gt[coverage]
+    rec_c = rec[coverage]
+    err = angular_error_deg(gt_c.reshape(-1, 1, 2), rec_c.reshape(-1, 1, 2)).reshape(-1)
+    diff = nxy_to_unit(gt_c.reshape(-1, 1, 2)) - nxy_to_unit(rec_c.reshape(-1, 1, 2))
+    mse = float(np.mean(np.sum(diff.reshape(-1, 3) ** 2, axis=-1)))
+
+    return {
+        "mean_ang_deg": float(np.mean(err)),
+        "p50_ang_deg": float(np.percentile(err, 50)),
+        "p95_ang_deg": float(np.percentile(err, 95)),
+        "p99_ang_deg": float(np.percentile(err, 99)),
+        "max_ang_deg": float(np.max(err)),
+        "normal_mse": mse,
+        "normal_psnr_db": float(10.0 * np.log10(4.0 / (mse + EPS))),
+        "covered_pixels": covered,
+        "total_pixels": total,
+        "uncovered_pixels": uncovered,
+        "coverage_ratio": float(covered / max(total, 1)),
+    }
+
+
+def write_csv(path: Path, row: dict) -> None:
+    path.parent.mkdir(parents=True, exist_ok=True)
+    with path.open("w", newline="", encoding="utf-8") as f:
+        writer = csv.DictWriter(f, fieldnames=list(row.keys()))
+        writer.writeheader()
+        writer.writerow(row)
+
+
+def main() -> None:
+    ap = argparse.ArgumentParser(description="Dense texel-level normal metrics for PNDF/QEM meshbin outputs.")
+    ap.add_argument("--nxy-bin", required=True, type=Path)
+    ap.add_argument("--meshbin", required=True, type=Path)
+    ap.add_argument("--csv", required=True, type=Path, help="output one-line metrics CSV")
+    args = ap.parse_args()
+
+    gt = load_nxy_bin(args.nxy_bin)
+    H, W = gt.shape[:2]
+    mesh_w, mesh_h, vertices, faces, mesh_format = load_meshbin(args.meshbin)
+
+    rec, coverage = rasterize_mesh_to_grid(vertices, faces, H, W)
+    row = {
+        "nxy_bin": str(args.nxy_bin),
+        "meshbin": str(args.meshbin),
+        "mesh_format": mesh_format,
+        "nxy_width": W,
+        "nxy_height": H,
+        "mesh_declared_width": mesh_w,
+        "mesh_declared_height": mesh_h,
+        "vertices": int(len(vertices)),
+        "faces": int(len(faces)),
+        **compute_metrics(gt, rec, coverage),
+    }
+    write_csv(args.csv, row)
+
+    print(
+        f"wrote {args.csv} | V={len(vertices)} F={len(faces)} "
+        f"coverage={row['coverage_ratio']:.6f} mean={row['mean_ang_deg']:.4f}deg "
+        f"p99={row['p99_ang_deg']:.4f}deg"
+    )
+
+
+if __name__ == "__main__":
+    main()
