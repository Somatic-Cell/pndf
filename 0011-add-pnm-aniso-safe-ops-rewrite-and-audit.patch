+#!/usr/bin/env python3
+"""Small meshbin topology audit helper for p-NDF mesh experiments."""
+import argparse
+import collections
+import math
+import struct
+from pathlib import Path
+
+
+def read_meshbin(path: Path):
+    data = path.read_bytes()
+    off = 0
+    if len(data) < 16:
+        raise ValueError("file too small")
+    w, h, V, F = struct.unpack_from("<iiii", data, off)
+    off += 16
+    verts = []
+    for _ in range(V):
+        if off + 16 > len(data):
+            raise ValueError("truncated vertex array")
+        verts.append(struct.unpack_from("<ffff", data, off))
+        off += 16
+    faces = []
+    for _ in range(F):
+        if off + 12 > len(data):
+            raise ValueError("truncated face array")
+        faces.append(struct.unpack_from("<iii", data, off))
+        off += 12
+    return w, h, verts, faces
+
+
+def edge_key(a, b):
+    return (a, b) if a <= b else (b, a)
+
+
+def tri_key(f):
+    return tuple(sorted(f))
+
+
+def main():
+    ap = argparse.ArgumentParser()
+    ap.add_argument("meshbin")
+    args = ap.parse_args()
+
+    w, h, verts, faces = read_meshbin(Path(args.meshbin))
+    V = len(verts)
+    F = len(faces)
+
+    edge_faces = collections.defaultdict(list)
+    tri_counts = collections.Counter()
+    degenerate = 0
+    invalid = 0
+    for fi, f in enumerate(faces):
+        if any(v < 0 or v >= V for v in f):
+            invalid += 1
+            continue
+        if f[0] == f[1] or f[1] == f[2] or f[2] == f[0]:
+            degenerate += 1
+        tri_counts[tri_key(f)] += 1
+        for a, b in ((f[0], f[1]), (f[1], f[2]), (f[2], f[0])):
+            edge_faces[edge_key(a, b)].append(fi)
+
+    E = len(edge_faces)
+    boundary = sum(1 for fs in edge_faces.values() if len(fs) == 1)
+    nonmanifold = sum(1 for fs in edge_faces.values() if len(fs) > 2)
+    duplicate_faces = sum(c - 1 for c in tri_counts.values() if c > 1)
+    euler = V - E + F
+
+    # Valence of vertices in the undirected graph.
+    nbrs = [set() for _ in range(V)]
+    for (a, b) in edge_faces:
+        if 0 <= a < V and 0 <= b < V:
+            nbrs[a].add(b)
+            nbrs[b].add(a)
+    vals = [len(s) for s in nbrs]
+
+    print(f"meshbin,{args.meshbin}")
+    print(f"declared_width,{w}")
+    print(f"declared_height,{h}")
+    print(f"vertices,{V}")
+    print(f"faces,{F}")
+    print(f"expected_faces_for_closed_torus,{2*V}")
+    print(f"unique_edges,{E}")
+    print(f"euler_characteristic,{euler}")
+    print(f"invalid_faces,{invalid}")
+    print(f"degenerate_faces,{degenerate}")
+    print(f"duplicate_faces,{duplicate_faces}")
+    print(f"boundary_edges,{boundary}")
+    print(f"nonmanifold_edges,{nonmanifold}")
+    if vals:
+        print(f"valence_min,{min(vals)}")
+        print(f"valence_max,{max(vals)}")
+        print(f"valence_mean,{sum(vals)/len(vals):.6g}")
+
+    ok = (invalid == 0 and degenerate == 0 and duplicate_faces == 0 and boundary == 0 and nonmanifold == 0)
+    # F=2V and euler=0 are expected for a closed triangulated torus after compact meshbin output.
+    ok = ok and (F == 2 * V) and (euler == 0)
+    print(f"status,{'OK' if ok else 'FAIL'}")
+
+
+if __name__ == "__main__":
+    main()
