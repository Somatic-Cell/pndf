+def edge_intersection_audit(
+    uv: list[tuple[float, float]],
+    edges: list[tuple[int, int]],
+    grid_res: int,
+    eps: float,
+    max_report: int,
+):
+    segs = translated_edge_copies(uv, edges, pad=0.0)
+    cells: dict[tuple[int, int], list[int]] = collections.defaultdict(list)
+    for i, s in enumerate(segs):
+        ix0, iy0, ix1, iy1 = cell_range_for_bbox(bbox2((s.p0, s.p1)), grid_res)
+        for iy in range(iy0, iy1 + 1):
+            for ix in range(ix0, ix1 + 1):
+                cells[(ix, iy)].append(i)
+
+    checked = set()
+    count = 0
+    samples = []
+    for ids in cells.values():
+        n = len(ids)
+        for ia in range(n):
+            aidx = ids[ia]
+            sa = segs[aidx]
+            for ib in range(ia + 1, n):
+                bidx = ids[ib]
+                if aidx > bidx:
+                    pair = (bidx, aidx)
+                else:
+                    pair = (aidx, bidx)
+                if pair in checked:
+                    continue
+                checked.add(pair)
+                sb = segs[bidx]
+                if sa.edge == sb.edge:
+                    continue
+                if set(sa.edge) & set(sb.edge):
+                    continue
+                if segments_intersect(sa.p0, sa.p1, sb.p0, sb.p1, eps=eps):
