+def point_in_triangle(p, tri: TriangleCopy, eps: float) -> bool:
+    bc = barycentric(p, (tri.p0, tri.p1, tri.p2))
+    if bc is None:
+        return False
+    return bc[0] >= -eps and bc[1] >= -eps and bc[2] >= -eps
