+    def is_top_left(a, b):
+        dy = b[1] - a[1]
+        dx = b[0] - a[0]
+        return dy > 0.0 or (abs(dy) <= eps and dx < 0.0)
+
+    edges = ((pts[0], pts[1]), (pts[1], pts[2]), (pts[2], pts[0]))
+    for a, b in edges:
+        e = signed_area2(a, b, p)
+        if e > eps:
+            continue
+        if e < -eps:
+            return False
+        if not is_top_left(a, b):
