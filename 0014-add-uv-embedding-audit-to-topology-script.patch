+def normalize_uvs(verts: list[tuple[float, float, float, float]], w: int, h: int) -> list[tuple[float, float]]:
+    uv = [(float(v[0]), float(v[1])) for v in verts]
+    if not uv:
+        return []
+    max_abs = max(max(abs(u), abs(v)) for u, v in uv)
+    if max_abs > 2.0:
+        uv = [(u / float(w), v / float(h)) for u, v in uv]
+    return [(wrap01(u), wrap01(v)) for u, v in uv]
+
