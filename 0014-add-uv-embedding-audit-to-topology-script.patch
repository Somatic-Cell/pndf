+def point_in_triangle_top_left(p, tri: TriangleCopy, eps: float) -> bool:
+    # Half-open rasterization rule.  This avoids double-counting sample points
+    # that lie exactly on a shared edge.  The triangle is first made CCW so the
+    # same top-left convention applies independent of input face orientation.
+    pts = [tri.p0, tri.p1, tri.p2]
+    if signed_area2(pts[0], pts[1], pts[2]) < 0.0:
+        pts[1], pts[2] = pts[2], pts[1]
