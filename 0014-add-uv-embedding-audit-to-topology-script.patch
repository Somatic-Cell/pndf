+def geometry_audit(uv: list[tuple[float, float]], faces: list[tuple[int, int, int]]):
+    areas = []
+    min_angles = []
+    max_edge_lengths = []
+    negative = 0
+    tiny = 0
+    for f in faces:
+        if any(i < 0 or i >= len(uv) for i in f):
+            continue
+        p0, p1, p2 = unwrap_triangle(uv, f)
+        a2 = signed_area2(p0, p1, p2)
+        if a2 < 0.0:
+            negative += 1
+        area = 0.5 * abs(a2)
+        areas.append(area)
+        if area < 1.0e-18:
+            tiny += 1
+        e01 = math.dist(p0, p1)
+        e12 = math.dist(p1, p2)
+        e20 = math.dist(p2, p0)
+        max_edge_lengths.append(max(e01, e12, e20))
+        min_angles.append(min(angle_degrees(p1, p0, p2), angle_degrees(p0, p1, p2), angle_degrees(p0, p2, p1)))
+    return {
+        "uv_negative_oriented_faces": negative,
+        "uv_tiny_area_faces": tiny,
+        "uv_area_min": min(areas) if areas else float("nan"),
+        "uv_area_p01": percentile(areas, 1),
+        "uv_area_p05": percentile(areas, 5),
+        "uv_area_p50": percentile(areas, 50),
+        "uv_area_p95": percentile(areas, 95),
