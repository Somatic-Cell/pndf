+def run_embedding_audit(args, w, h, uv, faces, edge_faces):
+    grid_w = args.embedding_grid_width or w
+    grid_h = args.embedding_grid_height or h
+    if grid_w <= 0 or grid_h <= 0:
+        raise ValueError("embedding grid dimensions must be positive")
+
+    out = {}
+    out.update(geometry_audit(uv, faces))
+    out.update(
+        raster_coverage_audit(
+            uv, faces, grid_w, grid_h,
+            eps=args.embedding_eps,
+            offset_u=args.coverage_offset_u,
+            offset_v=args.coverage_offset_v,
+        )
+    )
+
+    edges = list(edge_faces.keys())
+    grid_res = args.spatial_hash_grid
+    if grid_res <= 0:
+        grid_res = max(32, int(round(math.sqrt(max(len(edges), 1)))))
+
+    if not args.skip_edge_intersections:
+        out.update(edge_intersection_audit(uv, edges, grid_res, eps=args.embedding_eps, max_report=args.max_report))
+    else:
+        out["edge_intersections"] = "SKIPPED"
+
+    if not args.skip_vertex_inside:
+        out.update(vertex_inside_triangle_audit(uv, faces, grid_res, eps=args.embedding_eps, max_report=args.max_report))
+    else:
+        out["vertex_inside_nonincident_triangle"] = "SKIPPED"
+
+    return out
