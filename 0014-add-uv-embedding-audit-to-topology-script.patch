+def wrap01(x: float) -> float:
+    x = math.fmod(x, 1.0)
+    if x < 0.0:
+        x += 1.0
+    return x
+
+
+def wrap_delta(x: float) -> float:
+    return (x + 0.5) % 1.0 - 0.5
