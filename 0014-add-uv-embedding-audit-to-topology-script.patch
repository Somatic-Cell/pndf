+def cell_range_for_bbox(bb, grid_res: int):
+    xmin, ymin, xmax, ymax = bb
+    ix0 = max(0, min(grid_res - 1, int(math.floor(xmin * grid_res))))
+    ix1 = max(0, min(grid_res - 1, int(math.floor(xmax * grid_res))))
+    iy0 = max(0, min(grid_res - 1, int(math.floor(ymin * grid_res))))
+    iy1 = max(0, min(grid_res - 1, int(math.floor(ymax * grid_res))))
+    return ix0, iy0, ix1, iy1
+
