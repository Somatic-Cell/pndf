+    ub, vb = uv[b]
+    uc, vc = uv[c]
+    p0 = (u0, v0)
+    p1 = (u0 + wrap_delta(ub - u0), v0 + wrap_delta(vb - v0))
+    p2 = (u0 + wrap_delta(uc - u0), v0 + wrap_delta(vc - v0))
+    return p0, p1, p2
