From 0015 Mon Sep 17 00:00:00 2001
From: ChatGPT <chatgpt@openai.com>
Date: Sat, 9 May 2026 00:00:00 +0000
Subject: [PATCH] Add periodic UV convexity guard to HE flip

The PMP half-edge flip legality check protects mesh connectivity, but it
is not a geometric embeddedness test in the periodic UV domain. Add a
CVPR2025-style local convexity guard before accepting a flip candidate.

The new guard unwraps the four vertices of the two-triangle patch into a
local periodic chart, rejects degenerate patches, requires the old shared
edge to be a proper diagonal, and requires the proposed new diagonal to
produce two consistently oriented non-degenerate triangles.

This is intentionally local: it is the isConvex-equivalent filter that
should be applied before the PNM energy comparison. Global UV embedding
audits remain separate diagnostics.
---
 apps/pndf_run_pnm_aniso_he.cpp | 116 +++++++++++++++++++++++++++++++++
 1 file changed, 116 insertions(+)

diff --git a/apps/pndf_run_pnm_aniso_he.cpp b/apps/pndf_run_pnm_aniso_he.cpp
--- a/apps/pndf_run_pnm_aniso_he.cpp
+++ b/apps/pndf_run_pnm_aniso_he.cpp
@@ -329,13 +329,129 @@
 double signed_area(const std::array<Vec2, 3>& uv) {
 
  const Vec2 e0 = uv[1] - uv[0];
 
  const Vec2 e1 = uv[2] - uv[0];
 
  return e0.x * e1.y - e0.y * e1.x;
 
 }
+
+double orient2d(Vec2 a, Vec2 b, Vec2 c) {
+
+ const Vec2 ab = b - a;
+
+ const Vec2 ac = c - a;
+
+ return ab.x * ac.y - ab.y * ac.x;
+
+}
+
+struct LocalFlipPatchUv {
+
+ Vec2 a;
+
+ Vec2 b;
+
+ Vec2 c;
+
+ Vec2 d;
+
+};
+
+LocalFlipPatchUv unwrap_flip_patch_uv(const HeMesh& he,
+
+                                      pmp::Vertex a,
+
+                                      pmp::Vertex b,
+
+                                      pmp::Vertex c,
+
+                                      pmp::Vertex d) {
+
+ LocalFlipPatchUv p;
+
+ p.a = he.uv[a];
+
+ p.b = unwrap_near(he.uv[b], p.a);
+
+ Vec2 center = (p.a + p.b) * 0.5;
+
+ p.c = unwrap_near(he.uv[c], center);
+
+ p.d = unwrap_near(he.uv[d], center);
+
+ // Recenter once using all four vertices. This makes the chart symmetric
+
+ // for seam-crossing patches while still preserving the periodic copies
+
+ // chosen for a compact local neighbourhood.
+
+ center = (p.a + p.b + p.c + p.d) * 0.25;
+
+ p.a = unwrap_near(p.a, center);
+
+ p.b = unwrap_near(p.b, center);
+
+ p.c = unwrap_near(p.c, center);
+
+ p.d = unwrap_near(p.d, center);
+
+ return p;
+
+}
+
+bool finite_uv(Vec2 p) {
+
+ return std::isfinite(p.x) && std::isfinite(p.y);
+
+}
+
+bool is_periodic_uv_convex_flip_patch(const HeMesh& he,
+
+                                      pmp::Vertex a,
+
+                                      pmp::Vertex b,
+
+                                      pmp::Vertex c,
+
+                                      pmp::Vertex d) {
+
+ const LocalFlipPatchUv p = unwrap_flip_patch_uv(he, a, b, c, d);
+
+ if (!finite_uv(p.a) || !finite_uv(p.b) || !finite_uv(p.c) || !finite_uv(p.d)) return false;
+
+ // In the local chart, the current edge ab must be a true diagonal of the
+
+ // two-triangle patch: the opposite vertices c and d must lie on opposite
+
+ // sides of ab. The proposed diagonal cd must similarly separate a and b.
+
+ // This is the local screen-space isConvex test adapted to the torus UV
+
+ // domain. It does not replace the separate global embedding audit.
+
+ constexpr double eps = 1e-20;
+
+ const double old0 = orient2d(p.a, p.b, p.c);
+
+ const double old1 = orient2d(p.a, p.b, p.d);
+
+ const double new0 = orient2d(p.c, p.d, p.a);
+
+ const double new1 = orient2d(p.d, p.c, p.b);
+
+ if (std::abs(old0) <= eps || std::abs(old1) <= eps) return false;
+
+ if (std::abs(new0) <= eps || std::abs(new1) <= eps) return false;
+
+ if (old0 * old1 >= 0.0) return false;
+
+ if (new0 * new1 <= 0.0) return false;
+
+ return true;
+
+}
 
 Vec2 lerp_nxy(const HeMesh& he, pmp::Vertex a, pmp::Vertex b, pmp::Vertex c,
 
  double l0, double l1, double l2) {
@@ -491,6 +607,9 @@
  const pmp::Edge cd = he.mesh.find_edge(c, d);
 
  if (he.mesh.is_valid(cd) && !he.mesh.is_deleted(cd)) return out;
+
+ if (!is_periodic_uv_convex_flip_patch(he, a, b, c, d)) return out;
+
  const double before = face_energy(he, normal_map, f0) + face_energy(he, normal_map, f1);
 
  const std::array<pmp::Vertex, 3> t0{c, d, a};
-- 
